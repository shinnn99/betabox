{
  "name": "warehouse-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local Warehouse Agent — reads scanner data from Virtual COM ports and posts raw scan events to the Betacom backend.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "list-ports": "tsx src/list-ports.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@serialport/parser-delimiter": "^12.0.0",
    "dotenv": "^16.4.5",
    "serialport": "^12.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
